# LFS tracking for large binary/data files
*.fastq filter=lfs diff=lfs merge=lfs -text
*.fastq.gz filter=lfs diff=lfs merge=lfs -text
*.fasta filter=lfs diff=lfs merge=lfs -text
*.fasta.gz filter=lfs diff=lfs merge=lfs -text
*.fa filter=lfs diff=lfs merge=lfs -text
*.gff3 filter=lfs diff=lfs merge=lfs -text
*.cds filter=lfs diff=lfs merge=lfs -text
*.aa filter=lfs diff=lfs merge=lfs -text

# Exclude config files from LFS (small text files)
*.yml !filter !diff !merge text
*.yaml !filter !diff !merge text
*.txt !filter !diff !merge text

# Explicitly keep EVM weight files out of LFS
toydata/config/evm_weights.txt !filter !diff !merge text
config/evm_weights.txt !filter !diff !merge text

# The toy genome is committed as a raw blob, not an LFS pointer, so that
# `bin/annotate_toydata.sh` works in a clone made without git-lfs. Without this
# exception the *.fasta.gz rule above makes the file permanently dirty: the clean
# filter rewrites the 5.6 MB worktree copy to a 132-byte pointer at diff time.
toydata/genome/ath4.fasta.gz !filter !diff !merge -text
