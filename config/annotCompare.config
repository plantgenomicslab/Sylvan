## PASA annotation comparison configuration
## Stringent parameters to preserve EVM gene model quality
## See: https://github.com/PASApipeline/PASApipeline/issues/230

# database settings
DATABASE=__PASA_DATABASE_PATH__

#######################################################
# Parameters to specify to specific scripts in pipeline
# create a key = "script_name" + ":" + "parameter"
# assign a value as done above.

#script cDNA_annotation_comparer.dbi
cDNA_annotation_comparer.dbi:--MIN_PERCENT_OVERLAP=60
cDNA_annotation_comparer.dbi:--MIN_PERCENT_PROT_CODING=50
cDNA_annotation_comparer.dbi:--MIN_PERID_PROT_COMPARE=70
cDNA_annotation_comparer.dbi:--MIN_PERCENT_LENGTH_FL_COMPARE=70
cDNA_annotation_comparer.dbi:--MIN_PERCENT_LENGTH_NONFL_COMPARE=90
cDNA_annotation_comparer.dbi:--MIN_FL_ORF_SIZE=60
cDNA_annotation_comparer.dbi:--MIN_PERCENT_ALIGN_LENGTH=95
cDNA_annotation_comparer.dbi:--MIN_PERCENT_OVERLAP_GENE_REPLACE=85
cDNA_annotation_comparer.dbi:--STOMP_HIGH_PERCENTAGE_OVERLAPPING_GENE=70
cDNA_annotation_comparer.dbi:--TRUST_FL_STATUS=TRUE
cDNA_annotation_comparer.dbi:--MAX_UTR_EXONS=2
## GENETIC_CODE: omitted = universal (default). Options: Euplotes, Tetrahymena, Candida, Acetabularia
