#TODO: Add repeat coverage calculation... add to config as well
rule abInitioCoverage:
	output:
		f"{RESULTS_DIR}FILTER/augustus_coverage.bed",
		f"{RESULTS_DIR}FILTER/helixer_coverage.bed",
		f"{RESULTS_DIR}FILTER/repeat_coverage.bed",
		f"{RESULTS_DIR}FILTER/miniprot_coverage.bed"
	params:
		augustus = config_dict["Input"]["augustus_gff"],
		helixer = config_dict["Input"]["helixer_gff"],
		repeat = config_dict["Input"]["repeat_gff"],
		miniprot = config_dict["Input"]["miniprot_gff"],
		gff = config_dict['Input']['anot_gff'],
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate alignment
		grep -P '\tmRNA\t' {params.augustus} | \
		   cut -f1,4,5,7 > {params.results_dir}FILTER/augustus.bed

		grep -P '\tmRNA\t' {params.helixer} | \
		   cut -f1,4,5,7 > {params.results_dir}FILTER/helixer.bed

		cut -f1,4,5,7 {params.repeat} > {params.results_dir}FILTER/repeat.bed

		grep -P '\tmRNA\t' {params.miniprot} | \
		   cut -f1,4,5,7 > {params.results_dir}FILTER/miniprot.bed || true

		grep -P '\\tmRNA\\t' {params.gff} | \
			cut -f1,4,5,7,9 | \
			awk -F';' '{{print $1}}'| \
			sed 's/ID=//' | \
			sed 's/;.*//' > {params.results_dir}FILTER/prefilter.bed

		bedtools coverage -a {params.results_dir}FILTER/prefilter.bed -b {params.results_dir}FILTER/augustus.bed > {params.results_dir}FILTER/augustus_coverage.bed
		bedtools coverage -a {params.results_dir}FILTER/prefilter.bed -b {params.results_dir}FILTER/helixer.bed > {params.results_dir}FILTER/helixer_coverage.bed
		bedtools coverage -a {params.results_dir}FILTER/prefilter.bed -b {params.results_dir}FILTER/repeat.bed > {params.results_dir}FILTER/repeat_coverage.bed
		bedtools coverage -a {params.results_dir}FILTER/prefilter.bed -b {params.results_dir}FILTER/miniprot.bed > {params.results_dir}FILTER/miniprot_coverage.bed
		"""

rule lncRNA_pred:
	input: anot_cdna
	output: f"{RESULTS_DIR}FILTER/lncrna_predict.csv"
	params:
		lncdc_db = "$CONDA_PREFIX/share/lncdc_db"
	threads: config_dict["Threads"]["lncRNA_pred"]
	shell:'''
		micromamba activate lncdc
		python $CONDA_PREFIX/lib/python3.9/site-packages/bin/lncDC.py \
		-x {params.lncdc_db}/plant_selected_nostructure_hexamer_table.csv \
		-m {params.lncdc_db}/plant_selected_nostructure_xgb_model_SIF_PF.pkl \
		-p {params.lncdc_db}/plant_selected_nostructure_imputer_SIF_PF.pkl \
		-s {params.lncdc_db}/plant_selected_nostructure_scaler_SIF_PF.pkl \
		-t {threads} \
		-i {input} \
		-o {output}
		'''

rule busco:
	input: rules.makeCDSPep.output.pep
	output: f"{RESULTS_DIR}FILTER/busco_{config_dict['Input']['busco_lin']}/run_{config_dict['Input']['busco_lin']}/full_table.tsv"
	params:
		busco_lin = config_dict["Input"]["busco_lin"],
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate filter
		busco -i {input} \
		-l {params.busco_lin} \
		-o {params.results_dir}FILTER/busco_{params.busco_lin} \
		-m protein \
		-f
		"""

rule filter:
	input:
		blast = f"{RESULTS_DIR}FILTER/BLASTP.OUT.TMP",
		rex = f"{RESULTS_DIR}FILTER/BLASTP.OUT.Rex",
		pfam = f"{RESULTS_DIR}FILTER/pfam.out",
		rsem = f"{RESULTS_DIR}FILTER/rsem_outdir/RSEM.isoforms.results",
		augustus = f"{RESULTS_DIR}FILTER/augustus_coverage.bed",
		helixer = f"{RESULTS_DIR}FILTER/helixer_coverage.bed",
		repeat = f"{RESULTS_DIR}FILTER/repeat_coverage.bed",
		miniprot = f"{RESULTS_DIR}FILTER/miniprot_coverage.bed",
		cov = f"{RESULTS_DIR}FILTER/cov.bed",
		lncrna = f"{RESULTS_DIR}FILTER/lncrna_predict.csv",
		busco = f"{RESULTS_DIR}FILTER/busco_{config_dict['Input']['busco_lin']}/run_{config_dict['Input']['busco_lin']}/full_table.tsv"
	output:
		f"{RESULTS_DIR}FILTER/filtered.gff3"
	params:
		anot_gff = config_dict["Input"]["anot_gff"],
		tpm = config_dict["Cutoff"]["tpm"],
		rsem_cov = config_dict["Cutoff"]["rsem_cov"],
		helixer_cov = config_dict["Cutoff"]["helixer_cov"],
		augustus_cov = config_dict["Cutoff"]["augustus_cov"],
		repeat_cov = config_dict["Cutoff"]["repeat_cov"],
		blast_pident = config_dict["Cutoff"]["blast_pident"],
		blast_qcovs = config_dict["Cutoff"]["blast_qcovs"],
		rex_pident = config_dict["Cutoff"]["rex_pident"],
		rex_qcovs = config_dict["Cutoff"]["rex_qcovs"],
		miniprot_cov = config_dict["Cutoff"]["miniprot_cov"],
		regex = config_dict["Input"]["chrom_regex"],
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate base
		/opt/envs/base/bin/python3 bin/Filter.py \
		{params.anot_gff} \
		{input.busco} \
		--tpm {params.tpm} \
		--rcov {params.rsem_cov} \
		--hcov {params.helixer_cov} \
		--acov {params.augustus_cov} \
		--repcov {params.repeat_cov} \
		--blast-pident {params.blast_pident} \
		--blast-qcovs {params.blast_qcovs} \
		--rex-pident {params.rex_pident} \
		--rex-qcovs {params.rex_qcovs} \
		--miniprot-cov {params.miniprot_cov} \
		--seed 123 \
		--trees 100 \
		--predictors 5 \
		--recycle 0.95 \
		--max-iter 10 \
		--chromRegex '{params.regex}' \
		--output {output} \
		--output-dir {params.results_dir}FILTER
	"""
