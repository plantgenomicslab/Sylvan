	output:
		f"{RESULTS_DIR}FILTER/splitPep/" + pep_string + ".part_{part}.blastRex.tmp"
	threads: config_dict["Threads"]["blast"]
	params:
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate genepred
		blastp \
			-query {input.fa} \
