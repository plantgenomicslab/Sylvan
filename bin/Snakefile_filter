import yaml, sys, os, re
import pandas as pd
from pathlib import Path
from snakemake.exceptions import WorkflowError

# TODO: file handling for re-runs is inadequate ... if a new gff is used many outputs need to be overwritten

# Results directory prefix - all outputs will be placed under this directory
RESULTS_DIR = os.environ.get("SYLVAN_RESULTS_DIR", "results/")

# Load config file (can be overridden via SYLVAN_FILTER_CONFIG environment variable)
# Default points to the in-repo template config/config_filter.yml (run from the
# repo root). Set SYLVAN_FILTER_CONFIG to use another config, e.g.:
#   SYLVAN_FILTER_CONFIG=toydata/config/config_filter.yml snakemake ... --snakefile bin/Snakefile_filter
config_file_path = os.environ.get('SYLVAN_FILTER_CONFIG', 'config/config_filter.yml')
print(f"[Sylvan] Using config: {config_file_path}", file=sys.stderr)
try:
	with open(config_file_path, 'r') as config_file:
		config_dict=yaml.safe_load(config_file)
except FileNotFoundError:
	sys.exit(
		f"Config file not found: {config_file_path} ... "
		"set SYLVAN_FILTER_CONFIG (e.g. SYLVAN_FILTER_CONFIG=toydata/config/config_filter.yml) "
		"or run from the repo root where config/config_filter.yml exists."
	)
except yaml.YAMLError as e:
	sys.exit("Could not load configs! Check config.yaml ...")

# Check inputs
for key in config_dict["Input"]:
	if key in ("chrom_regex", "busco_lin"):
		continue
	if key == "HmmDB":
		hmm_path = config_dict["Input"][key]
		if hmm_path.startswith("/usr/local/") or hmm_path == "placeholder":
			continue  # Will use conda env default
		elif not os.path.exists(hmm_path):
			sys.exit(f"Could not find {hmm_path}! Check {key} in config.yaml ...")
		continue
	if not os.path.exists(config_dict["Input"][key]):
		sys.exit(f"Could not find {config_dict['Input'][key]}! Check {key} in config.yaml ...")


# Singularity container with pre-built micromamba environments
singularity: config_dict.get("Input", {}).get("singularity", "") or config_dict.get("Singularity", "")

# Set up micromamba shell hook for all shell commands.
# Cache the hook output to a host-mounted file so each rule sources it instead of
# forking `micromamba shell hook` on every job. That fork has a hardcoded 5s
# timeout in micromamba and intermittently gets killed under heavy cluster I/O,
# which leaves the `micromamba` shell function undefined and crashes rules right
# at `micromamba activate` (observed on blastRex, calculateRSEMExpression_PAIRED).
#
# The cache is built under an flock so only ONE job generates it at a time (no
# thundering herd of simultaneous forks at startup), with a few retries; every
# other job just `source`s it. An inline `eval` fallback covers a missing/corrupt
# cache so activation still works. Delete the cache when the .sif image changes.
_HOOK_CACHE = f"{RESULTS_DIR}/.micromamba_hook.sh"
shell.prefix(
    'set +u; export MAMBA_NO_BANNER=1; '
    f'if [ ! -s "{_HOOK_CACHE}" ]; then '
    f'  ( if command -v flock >/dev/null 2>&1; then flock -w 120 9 || true; fi; '
    f'    if [ ! -s "{_HOOK_CACHE}" ]; then '
    f'      for _i in 1 2 3; do '
    f'        if /usr/local/bin/micromamba shell hook -s bash > "{_HOOK_CACHE}.tmp.$$" 2>/dev/null && [ -s "{_HOOK_CACHE}.tmp.$$" ]; then '
    f'          mv -f "{_HOOK_CACHE}.tmp.$$" "{_HOOK_CACHE}"; break; '
    f'        fi; '
    f'        rm -f "{_HOOK_CACHE}.tmp.$$"; sleep 2; '
    f'      done; '
    f'    fi; '
    f'  ) 9>"{_HOOK_CACHE}.lock" || true; '
    f'fi; '
    f'source "{_HOOK_CACHE}" 2>/dev/null || eval "$(/usr/local/bin/micromamba shell hook -s bash 2>/dev/null)" || true; '
    'set -u; '
)

# Get rnaseq run wildcards
rna_seq = config_dict["Input"]["rna_seq"]
bams = []
rsem = []
# Support both _1/_2 and _R1/_R2 naming conventions for paired-end reads
pair1_re = re.compile(r"(.+)(_1|_R1)\.fastq\.gz$")
pair2_re = re.compile(r"(.+)(_2|_R2)\.fastq\.gz$")
# Store mapping of sample names to actual file paths.
# Each sample dict holds EITHER 'fwd'+'rev' (paired-end) OR 'single' (single-end).
sample_to_files = {}
for root, dirs, files in os.walk(rna_seq):
	for fi in files:
		# Only consider gzipped FASTQ; skip sidecar files (e.g. *.samtools.log,
		# .done markers) and hidden files so they are never mistaken for samples.
		if fi.startswith('.') or not fi.endswith('.fastq.gz'):
			continue

		match1 = pair1_re.match(fi)
		if match1:
			sample_name = match1.group(1)
			bams.append(f"{RESULTS_DIR}FILTER/STAR/{sample_name}.STAR_pairedend.bamAligned.toTranscriptome.out.bam")
			rsem.append(f"{RESULTS_DIR}FILTER/rsem_outdir/{sample_name}.isoforms.results")
			if sample_name not in sample_to_files:
				sample_to_files[sample_name] = {}
			sample_to_files[sample_name]['fwd'] = os.path.join(root, fi)
			continue

		match2 = pair2_re.match(fi)
		if match2:
			sample_name = match2.group(1)
			if sample_name not in sample_to_files:
				sample_to_files[sample_name] = {}
			sample_to_files[sample_name]['rev'] = os.path.join(root, fi)
			continue

		# Single-end: a *.fastq.gz that is neither _1/_R1 nor _2/_R2.
		# sample_name = filename minus the .fastq.gz suffix.
		sample_name = re.sub(r"\.fastq\.gz$", "", fi)
		bams.append(f"{RESULTS_DIR}FILTER/STAR/{sample_name}.STAR_singleend.bamAligned.toTranscriptome.out.bam")
		rsem.append(f"{RESULTS_DIR}FILTER/rsem_outdir/{sample_name}.isoforms.results")
		if sample_name not in sample_to_files:
			sample_to_files[sample_name] = {}
		sample_to_files[sample_name]['single'] = os.path.join(root, fi)
	break

# Fail fast when no RNA-seq fastq were found. Otherwise bams/rsem stay empty and
# downstream mergeSTAR/mergeRSEM run on empty input, silently dropping expression
# evidence (or dying with a cryptic samtools error). Stop here with a clear message.
if not rsem:
	raise WorkflowError(
		f"No RNA-seq fastq found in {rna_seq} (expected .fastq.gz paired-end "
		"_1/_2 | _R1/_R2, or single-end). Expression evidence would be silently missing."
	)

# Classify samples so the single/paired RSEM rules never both match the same
# {run}.isoforms.results target (see wildcard_constraints on the RSEM rules).
# A sample is either single-end ('single') or paired-end ('fwd'), never both.
single_sample_names = sorted(n for n, f in sample_to_files.items() if 'single' in f)
paired_sample_names = sorted(n for n, f in sample_to_files.items() if 'fwd' in f)

def _sample_name_constraint(names):
	# Regex matching exactly the given sample names. When the list is empty the
	# pattern 'a^' matches nothing, so the corresponding RSEM rule is inert
	# (keeps all-single and all-paired directories unambiguous).
	return "|".join(re.escape(n) for n in names) if names else r"a^"

def get_fastq_fwd(wildcards):
	return sample_to_files[wildcards.run]['fwd']

def get_fastq_rev(wildcards):
	return sample_to_files[wildcards.run]['rev']

def get_fastq_single(wildcards):
	return sample_to_files[wildcards.run]['single']

pep_string = re.sub(r"\.fa.*$", "", config_dict["Input"]["anot_gff"] + ".fa")
pep_string = re.sub(r"^.*\/", "", pep_string)

os.makedirs(f"{RESULTS_DIR}logs", exist_ok=True)
os.makedirs(f"{RESULTS_DIR}FILTER/rsem_outdir", exist_ok=True)

def inputAll(wc):
	input = [f"{RESULTS_DIR}FILTER/pfam.out",
		f"{RESULTS_DIR}FILTER/BLASTP.OUT.TMP",
		f"{RESULTS_DIR}FILTER/rsem_outdir/RSEM.isoforms.results",
		f"{RESULTS_DIR}FILTER/STAR/merged.bam",
		f"{RESULTS_DIR}FILTER/cov.bed",
		f"{RESULTS_DIR}FILTER/homolog.pdb",
		f"{RESULTS_DIR}FILTER/augustus_coverage.bed",
		f"{RESULTS_DIR}FILTER/helixer_coverage.bed",
		f"{RESULTS_DIR}FILTER/repeat_coverage.bed",
		f"{RESULTS_DIR}FILTER/filtered.gff3",
		f"{RESULTS_DIR}FILTER/{pep_string}.cdna",
		f"{RESULTS_DIR}FILTER/{pep_string}.pep"]
		#f"{RESULTS_DIR}FILTER/busco_eudicots_odb10/run_eudicots_odb10/full_table.tsv"]
	for i in range(1,21):
		input.append(f"{RESULTS_DIR}FILTER/splitPep/{pep_string}.part_{i:03d}.pep")
		input.append(f"{RESULTS_DIR}FILTER/splitPep/{pep_string}.part_{i:03d}.blast.tmp")

	return(input)

anot_cdna = f"{RESULTS_DIR}FILTER/{pep_string}.cdna"
anot_mrna = f"{RESULTS_DIR}FILTER/{pep_string}.mrna"   # Full mRNA (exons incl. UTRs) for RSEM
anot_pep = f"{RESULTS_DIR}FILTER/{pep_string}.pep"

rule all:
	input: inputAll

rule makeCDSPep:
	output:
		cdna = anot_cdna,
		pep = anot_pep,
		mrna = anot_mrna
	params:
		genome = config_dict["Input"]["genome"],
		gff =  config_dict["Input"]["anot_gff"]
	shell:"""
		micromamba activate filter
		gff3_file_to_proteins.pl {params.gff} {params.genome} cDNA > {output.cdna}

		gff3_file_to_proteins.pl {params.gff} {params.genome} prot > {output.pep}

		# Extract full mRNA (exons incl. UTRs) for RSEM — must match STAR transcriptome BAM lengths
		micromamba activate annotation
		gffread {params.gff} -g {params.genome} -w {output.mrna} || true
		"""

rule PfamScan:
	input: anot_pep
	output: f"{RESULTS_DIR}FILTER/pfam.out"
	threads: config_dict["Threads"]["PfamScan"]
	params:
		hmm = config_dict['Input']['HmmDB']
	shell:"""
		micromamba activate filter
		pfam_scan.pl \
			-fasta {input} \
			-dir {params.hmm} \
			-cpu {threads} \
			-outfile {output}
		"""

# Prepare RSEM files — use full mRNA (exons incl. UTRs) to match STAR transcriptome BAM lengths
rule prepRSEM:
	input: anot_mrna
	output: f"{anot_mrna}.seq"
	threads: config_dict["Threads"]["prepRSEM"]
	params: mrna = anot_mrna
	shell: """
		micromamba activate filter
		rsem-prepare-reference \
		-p {threads} \
		{input} \
		{params.mrna}
		"""

rule fastp_PAIRED:
	input:
		fwd = get_fastq_fwd,
		rev = get_fastq_rev
	output:
		fwd = f"{RESULTS_DIR}GETA/fastp/paired/{{run}}_1.fq.gz",
		rev = f"{RESULTS_DIR}GETA/fastp/paired/{{run}}_2.fq.gz"
	threads: config_dict["Threads"]["fastp_PAIRED"]
	params:
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate alignment
		fastp --detect_adapter_for_pe \
			--overrepresentation_analysis \
			--cut_right \
			--thread {threads} \
			--json {params.results_dir}GETA/fastp/paired/{wildcards.run}.fastp.json \
			--html {params.results_dir}GETA/fastp/paired/{wildcards.run}.fastp.html \
			-i {input.fwd} -I  {input.rev} \
			-o {output.fwd} -O {output.rev}
		"""

rule STAR_index:
	output: temp(f"{RESULTS_DIR}FILTER/STAR/SA")
	threads: config_dict["Threads"]["STAR_index"]
	params:
		g = config_dict["Input"]["genome"],
		gff = config_dict["Input"]["anot_gff"],
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate alignment
		STAR \
		--runThreadN {threads} \
		--runMode genomeGenerate \
		--genomeDir {params.results_dir}FILTER/STAR \
		--genomeFastaFiles {params.g} \
		--genomeSAindexNbases 12 \
		--sjdbGTFfile {params.gff} \
		--sjdbGTFtagExonParentTranscript Parent \
		--outTmpDir {params.results_dir}FILTER/STAR/_STARtmp_index
		"""

rule STAR_paired:
	input:
		g  = f"{RESULTS_DIR}FILTER/STAR/SA",
		one = f"{RESULTS_DIR}GETA/fastp/paired/{{run}}_1.fq.gz",
		two = f"{RESULTS_DIR}GETA/fastp/paired/{{run}}_2.fq.gz",
	output: temp(f"{RESULTS_DIR}FILTER/STAR/{{run}}.STAR_pairedend.bamAligned.toTranscriptome.out.bam")
	threads: config_dict["Threads"]["STAR"]
	params:
		results_dir = RESULTS_DIR
	shell: """
			micromamba activate alignment
			STAR --runMode alignReads \
			--runThreadN {threads} \
			--outFilterMultimapNmax 10 \
			--alignIntronMin 25 \
			--alignIntronMax 25000 \
			--genomeDir {params.results_dir}FILTER/STAR \
			--outSAMtype BAM SortedByCoordinate \
			--limitBAMsortRAM 216000000000 \
			--outBAMsortingBinsN 200 \
			--outSAMattributes XS \
			--outSAMstrandField intronMotif \
			--outFileNamePrefix {params.results_dir}FILTER/STAR/{wildcards.run}.STAR_pairedend.bam \
			--outTmpDir {params.results_dir}FILTER/STAR/{wildcards.run}_STARtmp \
			--readFilesCommand gunzip -c \
			--readFilesIn {input.one} {input.two} \
			--quantMode TranscriptomeSAM \
			--quantTranscriptomeSAMoutput BanSingleEnd_BanIndels_ExtendSoftclip \
			--alignEndsType EndToEnd
			"""

