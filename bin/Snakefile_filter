rule calculateRSEMExpression_PAIRED:
	wildcard_constraints:
		run = _sample_name_constraint(paired_sample_names)
	input:
		prep = f"{anot_mrna}.seq",
		bam = f"{RESULTS_DIR}FILTER/STAR/{{run}}.STAR_pairedend.bamAligned.toTranscriptome.out.bam"
	output: f"{RESULTS_DIR}FILTER/rsem_outdir/{{run}}.isoforms.results"
	threads: config_dict["Threads"]["calculateRSEMExpression"]
	params:
		mrna = anot_mrna,
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate filter
		rsem-calculate-expression \
		--no-bam-output -p {threads} \
		--alignments \
		--paired-end {input.bam} {params.mrna} {params.results_dir}FILTER/rsem_outdir/{wildcards.run}
		"""

rule calculateRSEMExpression_SINGLE:
	wildcard_constraints:
		run = _sample_name_constraint(single_sample_names)
	input:
		prep = f"{anot_mrna}.seq",
		bam = f"{RESULTS_DIR}FILTER/STAR/{{run}}.STAR_singleend.bamAligned.toTranscriptome.out.bam"
	output: f"{RESULTS_DIR}FILTER/rsem_outdir/{{run}}.isoforms.results"
	threads: config_dict["Threads"]["calculateRSEMExpression"]
	params:
		mrna = anot_mrna,
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate filter
		rsem-calculate-expression \
		--no-bam-output -p {threads} \
		--alignments {input.bam} {params.mrna} {params.results_dir}FILTER/rsem_outdir/{wildcards.run}
		"""

rule mergeRSEM:
	input: rsem
	output: f"{RESULTS_DIR}FILTER/rsem_outdir/RSEM.isoforms.results"
	run:
		if not input:
			raise ValueError(
				"mergeRSEM: no RSEM isoforms.results inputs — no RNA-seq samples were "
				f"detected under Input.rna_seq='{rna_seq}'. Ensure the directory contains "
				"single-end reads (<name>.fastq.gz) or paired-end reads "
				"(<name>_1/_2 or <name>_R1/_R2.fastq.gz)."
			)
		num_inputs = len(input)
		summary = pd.read_csv(input.pop(0), sep="\t", usecols=["transcript_id", "TPM"])
		
		for result in input:
			try:
				current = pd.read_csv(result, sep="\t", usecols=["transcript_id", "TPM"])
				summary["TPM"] = summary["TPM"] + current["TPM"]
			except (pd.errors.EmptyDataError, ValueError, KeyError) as e:
				print(f"WARNING: Error parsing {result}: {e}")
				num_inputs -= 1
		
		summary["TPM"] = summary["TPM"]/num_inputs
		summary.to_csv(output[0], sep="\t", index=False, header=True)

rule mergeSTAR:
	input: bams
	output: temp(f"{RESULTS_DIR}FILTER/STAR/merged.bam")
	threads: config_dict["Threads"]["mergeSTAR"]
	shell:"""
			micromamba activate alignment
			samtools merge -f \
			--threads {threads} \
			{output} \
			{input}
		"""

rule sortSTAR:
	input: f"{RESULTS_DIR}FILTER/STAR/merged.bam"
	output: temp(f"{RESULTS_DIR}FILTER/STAR/sorted.bam")
	threads: config_dict["Threads"]["sortSTAR"]
	params:
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate alignment
		samtools sort \
		-@ {threads} \
		-o {params.results_dir}FILTER/STAR/sorted.bam \
		{input}
		"""

rule coverage:
	input: f"{RESULTS_DIR}FILTER/STAR/sorted.bam"
	output: f"{RESULTS_DIR}FILTER/cov.bed"
	params:
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate alignment
		samtools view -H {input} | \
		grep '@SQ' | \
		cut -f2,3 | \
		sed 's/[SL]N://g' \
		> {params.results_dir}FILTER/transcriptome_chromSizes.txt

		awk '{{print $1 \"\\t1\\t\" $2}}' {params.results_dir}FILTER/transcriptome_chromSizes.txt > {params.results_dir}FILTER/gene.bed

		bedtools coverage \
		-sorted \
		-g {params.results_dir}FILTER/transcriptome_chromSizes.txt \
		-a {params.results_dir}FILTER/gene.bed \
		-b {input} \
		> {output}
		"""
		
		

rule blastDB:
	input: config_dict["Input"]["protein"]
	output: f"{RESULTS_DIR}FILTER/homolog.pdb"
	params:
		results_dir = RESULTS_DIR
	shell: "micromamba activate genepred && makeblastdb -in {input} -dbtype prot -out {params.results_dir}FILTER/homolog"

rule blastRexDB:
	input: config_dict['Input']['RexDB']
	output: f"{RESULTS_DIR}FILTER/rexdb.pdb"
	params:
		results_dir = RESULTS_DIR
	shell: "micromamba activate genepred && makeblastdb -in {input} -dbtype prot -out {params.results_dir}FILTER/rexdb"

num = []
for i in range(1,21):
        num.append(f"{i:03d}")

rule splitPep:
	input: anot_pep
	output: expand(f"{RESULTS_DIR}FILTER/splitPep/" + pep_string + ".part_{number}.pep", number=num)
	params:
		results_dir = RESULTS_DIR
	shell: "micromamba activate genepred && seqkit split -p 20 -O {params.results_dir}FILTER/splitPep {input}"

rule blast:
	input:
		wait = f"{RESULTS_DIR}FILTER/homolog.pdb",
		fa = f"{RESULTS_DIR}FILTER/splitPep/" + pep_string + ".part_{part}.pep"
	output:
		f"{RESULTS_DIR}FILTER/splitPep/" + pep_string + ".part_{part}.blast.tmp"
	threads: config_dict["Threads"]["blast"]
	params:
		results_dir = RESULTS_DIR
	shell:"""
		micromamba activate genepred
		blastp \
			-query {input.fa} \
			-db {params.results_dir}FILTER/homolog \
			-out {output} \
			-evalue 1e-15 \
			-outfmt '6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore qcovs' \
			-num_threads {threads} \
			-num_alignments 1
		"""

rule combineBlast:
	input: expand(f"{RESULTS_DIR}FILTER/splitPep/" + pep_string + ".part_{number}.blast.tmp", number=num)
	output: f"{RESULTS_DIR}FILTER/BLASTP.OUT.TMP"
	params:
		results_dir = RESULTS_DIR
	shell: "cat {params.results_dir}FILTER/splitPep/" + pep_string + ".part_*.blast.tmp > {output}"
		#| awk '{{if ($13 > " + str(config_dict["Cutoff"]["blast"]) + "){{print $0}}}}' > {output}"

