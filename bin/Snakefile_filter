			-evalue 1e-15 \
			-outfmt '6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore qcovs' \
			-num_threads {threads} \
			-num_alignments 1
		"""

rule combineBlastRex:
	input: expand(f"{RESULTS_DIR}FILTER/splitPep/" + pep_string + ".part_{number}.blastRex.tmp", number=num)
